<?xml version="1.0" encoding="UTF-8"?>
<!--
  logback-spring.xml — Structured logging configuration.
  Uses Spring profile-aware configuration blocks.
-->
<configuration>

    <!-- ── Properties ──────────────────────────────────────────────── -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{requestId:-no-req-id}] %-5level %logger{36} - %msg%n"/>

    <!-- ── Console appender (all profiles) ──────────────────────────── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ── Rolling file appender (prod profile) ──────────────────────── -->
    <springProfile name="prod">
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/pravarthana-hrms.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <!-- Daily rolling, keep 30 days -->
                <fileNamePattern>logs/pravarthana-hrms.%d{yyyy-MM-dd}.log</fileNamePattern>
                <maxHistory>30</maxHistory>
                <totalSizeCap>1GB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>
    </springProfile>

    <!-- ── Logger config by profile ─────────────────────────────────── -->

    <!-- Development: verbose, no file -->
    <springProfile name="dev">
        <logger name="com.pravarthana.hrms" level="DEBUG"/>
        <logger name="org.springframework.security" level="DEBUG"/>
        <logger name="org.hibernate.SQL" level="DEBUG"/>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- Production: quiet, file + console -->
    <springProfile name="prod">
        <logger name="com.pravarthana.hrms" level="INFO"/>
        <logger name="org.springframework.security" level="WARN"/>
        <logger name="org.hibernate" level="WARN"/>
        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

    <!-- Default (no profile set) -->
    <springProfile name="!dev &amp; !prod">
        <logger name="com.pravarthana.hrms" level="INFO"/>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

</configuration>
